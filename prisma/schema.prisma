// prisma/schema.prisma

generator client {
  provider = "prisma-client-js" //adapter
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum EmailStatus {
  SENT
  FAILED
}

enum GenerationMode {
  JD_BASED
  ROLE_BASED
  MANUAL  
}

model User {
  id    String @id @default(cuid())
  name  String?
  email String @unique
  password String?
  image String?

  // Profile setup
  resumePdfUrl    String?
  resumeText      String? @db.Text
  resumeDriveLink String?

  // SMTP config (encrypted)
  smtpEmail    String?
  smtpHost     String?
  smtpPort     Int?
  smtpPassword String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  emailLogs EmailLog[]
  accounts  Account[]
  sessions  Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recruiterEmail String
  subject        String
  body           String         @db.Text
  generationMode GenerationMode
  role           String?
  jobDescription String?        @db.Text
  status         EmailStatus
  errorMessage   String?        @db.Text
  createdAt      DateTime       @default(now())

  @@index([userId])
  @@index([recruiterEmail])
}

model DocumentationSection {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       DocumentationStep[]

  @@index([order])
}

model DocumentationStep {
  id          String   @id @default(cuid())
  sectionId   String
  title       String
  content     String   @db.Text
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section     DocumentationSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([order])
}